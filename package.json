{
  "name": "strudel-live",
  "version": "0.6.1",
  "private": true,
  "description": "Collaborative AI-driven Strudel live-coding — text, voice, MIDI, autotune",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "samples": "sampler ./samples",
    "dev:full": "concurrently -n app,samples -c blue,magenta \"npm run dev\" \"npm run samples\"",
    "build": "vite build",
    "start": "node server/production.mjs",
    "preview": "npm run build && npm run start",
    "patterns": "node scripts/list-patterns.mjs",
    "setup": "node scripts/setup.mjs",
    "check": "node scripts/check-setup.mjs",
    "voice": "node scripts/voice-jam.mjs",
    "osc:check": "node scripts/osc-check.mjs",
    "superdirt:help": "bash scripts/install-superdirt.sh",
    "sc:fetch": "node scripts/sc-fetch.mjs",
    "dj:analyze": "node scripts/dj-analyze.mjs",
    "dj:stems": "node scripts/dj-stems.mjs",
    "dj:deps": "bash scripts/install-dj-deps.sh",
    "synthdef": "node scripts/synthdef-cli.mjs",
    "osc:synthdef": "node scripts/synthdef-cli.mjs",
    "rave:help": "bash scripts/rave-help.sh",
    "rave:server": "node server/rave-server.mjs",
    "link:status": "node scripts/link-status.mjs",
    "panic": "node scripts/panic.mjs",
    "workflow:check": "node scripts/workflow-check.mjs",
    "audit": "node scripts/repo-audit.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@strudel/hydra": "1.2.6",
    "@strudel/repl": "1.3.0",
    "abletonlink": "^0.2.0-beta.0",
    "acorn": "^8.17.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "music-metadata": "^11.13.0",
    "music-tempo": "^1.0.3",
    "onnxruntime-node": "^1.27.0",
    "openai": "^4.77.0",
    "pitchy": "^4.1.0",
    "tone": "^15.0.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@strudel/sampler": "^0.2.4",
    "concurrently": "^9.1.2",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18"
  }
}
