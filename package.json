{
  "name": "strudel-live",
  "version": "0.2.0",
  "private": true,
  "description": "Collaborative AI-driven Strudel live-coding — text, voice, MIDI, autotune",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "samples": "sampler ./samples",
    "dev:full": "concurrently -n app,samples -c blue,magenta \"npm run dev\" \"npm run samples\"",
    "build": "vite build",
    "start": "node server/production.mjs",
    "preview": "npm run build && npm run start",
    "patterns": "node scripts/list-patterns.mjs",
    "setup": "node scripts/setup.mjs",
    "check": "node scripts/check-setup.mjs",
    "voice": "node scripts/voice-jam.mjs",
    "osc:check": "node scripts/osc-check.mjs",
    "superdirt:help": "bash scripts/install-superdirt.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@strudel/repl": "1.3.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "pitchy": "^4.1.0",
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "@strudel/sampler": "^0.2.4",
    "concurrently": "^9.1.2",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18"
  }
}
