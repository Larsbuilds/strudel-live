# Copy to .env:  cp .env.example .env

# OpenAI — KI-Generierung + Whisper-Spracheingabe
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# WHISPER_MODEL=whisper-1
# WHISPER_LANGUAGE=de

# Anthropic (optional, alternative KI)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI provider: openai | anthropic | ollama  (same semantic stack for all)
# AI_PROVIDER=openai

# --- Cloud fallback (stronger model, same tools/catalog) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# USE_OLLAMA=false

# --- Local Ollama (see docs/LOCAL-AI.md, docs/STATUS.md) ---
# AI_PROVIDER=ollama
# USE_OLLAMA=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=strudel-live
# OLLAMA_SYNTAX_MODEL=strudel-coder
# OLLAMA_DUAL_LLM=true
# PORT=5173
# OSC_HOST=127.0.0.1
# OSC_PORT=57120
