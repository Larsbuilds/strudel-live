# Copy to .env and fill in ONE of these keys:
#   cp .env.example .env

# OpenAI (recommended — gpt-4o-mini is fast and cheap)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Or Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: force a provider when both keys are set
# AI_PROVIDER=openai
